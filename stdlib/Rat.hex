// Exact rational arithmetic over canonical BigInt top/bottom pairs.
export opaque record Rat derives (Eq, Hash) = {
    top: BigInt,
    bottom: BigInt,
}

export exception DivideByZeroError(message: String)

export let create(top: BigInt, bottom: BigInt): Rat =
    if bottom == 0 then
        throw(DivideByZeroError("Rat.create: bottom is zero"))
    else
        // gcd uses Euclidean modulus internally after normalizing both operands.
        let divisor = BigInt.gcd(top, bottom)
        let reducedTop = BigInt.quot(top, divisor)
        let reducedBottom = BigInt.quot(bottom, divisor)
        if reducedBottom < 0 then
            Rat({top: -reducedTop, bottom: -reducedBottom})
        else
            Rat({top: reducedTop, bottom: reducedBottom})

export let top(value: Rat): BigInt = value.top
export let bottom(value: Rat): BigInt = value.bottom

export let add(left: Rat, right: Rat): Rat =
    create(
        left.top * right.bottom + right.top * left.bottom,
        left.bottom * right.bottom
    )

export let subtract(left: Rat, right: Rat): Rat =
    create(
        left.top * right.bottom - right.top * left.bottom,
        left.bottom * right.bottom
    )

export let multiply(left: Rat, right: Rat): Rat =
    create(left.top * right.top, left.bottom * right.bottom)

export let divide(left: Rat, right: Rat): Rat =
    create(left.top * right.bottom, left.bottom * right.top)

export let negate(value: Rat): Rat =
    Rat({top: -value.top, bottom: value.bottom})

export let reciprocal(value: Rat): Rat = create(value.bottom, value.top)

honor Ord<Rat> =
    compare(left, right) =
        let leftProduct = left.top * right.bottom
        let rightProduct = right.top * left.bottom
        if leftProduct < rightProduct then
            -1
        else
            if leftProduct > rightProduct then
                1
            else
                0

honor Show<Rat> =
    show(value) = "${value.top}/${value.bottom}"

honor Num<Rat> =
    add(left, right) = add(left, right)
    multiply(left, right) = multiply(left, right)
    fromNat(value) = create(value, 1)

honor Signed<Rat> =
    subtract(left, right) = subtract(left, right)
    negate(value) = negate(value)
    fromInt(value) = create(value, 1)

honor Frac<Rat> =
    divide(left, right) = divide(left, right)
