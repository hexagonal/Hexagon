// Exact rational arithmetic over canonical BigInt numerator/denominator pairs.
export opaque record Rat derives (Eq, Hash) = {
  numerator: BigInt,
  denominator: BigInt,
}

export exception ZeroDenominatorError(message: String)

export let create(numerator: BigInt, denominator: BigInt): Rat =
  if denominator == 0n
    throw(ZeroDenominatorError("a Rat denominator cannot be zero"))
  else
    // gcd uses Euclidean modulus internally after normalizing both operands.
    let divisor = BigInt.gcd(numerator, denominator)
    let reducedNumerator = BigInt.quot(numerator, divisor)
    let reducedDenominator = BigInt.quot(denominator, divisor)
    if reducedDenominator < 0n
      Rat({numerator: -reducedNumerator, denominator: -reducedDenominator})
    else Rat({numerator: reducedNumerator, denominator: reducedDenominator})

export let numerator(value: Rat): BigInt = value.numerator
export let denominator(value: Rat): BigInt = value.denominator

export let add(left: Rat, right: Rat): Rat =
  create(
    left.numerator * right.denominator + right.numerator * left.denominator,
    left.denominator * right.denominator
  )

export let subtract(left: Rat, right: Rat): Rat =
  create(
    left.numerator * right.denominator - right.numerator * left.denominator,
    left.denominator * right.denominator
  )

export let multiply(left: Rat, right: Rat): Rat =
  create(left.numerator * right.numerator, left.denominator * right.denominator)

export let divide(left: Rat, right: Rat): Rat =
  create(left.numerator * right.denominator, left.denominator * right.numerator)

export let negate(value: Rat): Rat =
  Rat({numerator: -value.numerator, denominator: value.denominator})

export let reciprocal(value: Rat): Rat = create(value.denominator, value.numerator)

honor Ord<Rat> =
  compare(left, right) =
    let leftProduct = left.numerator * right.denominator
    let rightProduct = right.numerator * left.denominator
    if leftProduct < rightProduct then -1
    else if leftProduct > rightProduct then 1
    else 0

honor Show<Rat> =
  show(value) = "${value.numerator}/${value.denominator}"

honor Num<Rat> =
  add(left, right) = add(left, right)
  subtract(left, right) = subtract(left, right)
  multiply(left, right) = multiply(left, right)
  negate(value) = negate(value)
  fromInt(value) = create(value, 1n)
